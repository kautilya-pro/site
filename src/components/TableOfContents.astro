---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	tocHeadings.length > 0 && (
		<nav aria-label="Table of Contents" class="toc">
			<p class="toc-title">On this page</p>
			<ul class="toc-list">
				{tocHeadings.map((heading) => (
					<li
						class:list={[
							'toc-item',
							heading.depth === 3 && 'toc-item--nested',
						]}
					>
						<a href={`#${heading.slug}`} class="toc-link">
							{heading.text}
						</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<script is:inline>
	function setupScrollSpy() {
		const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
		const tocLinks = document.querySelectorAll('.toc-link');
		if (headings.length === 0 || tocLinks.length === 0) return;

		const updateActiveTOC = () => {
			let current = '';
			const scrollPos = window.scrollY + 100; // 100px fixed offset from top

			// Find the active heading
			for (let i = 0; i < headings.length; i++) {
				const id = headings[i].id;
				// Ensure reliable absolute position relative to body
				const elementPosition = window.scrollY + headings[i].getBoundingClientRect().top;
				
				if (elementPosition <= scrollPos) {
					current = id;
				} else {
					break;
				}
			}

			// If scrolled past all headings to the very bottom, set the last heading as active
			if ((window.innerHeight + Math.round(window.scrollY)) >= document.documentElement.scrollHeight - 50) {
				current = headings[headings.length - 1].id;
			} else if (!current && headings.length > 0) {
				// Prevent weird behavior where no heading is selected yet
				current = headings[0].id;
			}

			tocLinks.forEach((link) => {
				link.classList.remove('active');
				const href = link.getAttribute('href');
				
				if (href === `#${current}`) {
					link.classList.add('active');

					// Smoothly auto-scroll the TOC nav if the active item goes out of its own visible frame
					const toc = document.querySelector('.toc');
					if (toc) {
						const linkRect = link.getBoundingClientRect();
						const tocRect = toc.getBoundingClientRect();

						if (linkRect.top < tocRect.top) {
							toc.scrollBy({ top: linkRect.top - tocRect.top - 16, behavior: 'smooth' }); // Scroll up
						} else if (linkRect.bottom > tocRect.bottom) {
							toc.scrollBy({ top: linkRect.bottom - tocRect.bottom + 16, behavior: 'smooth' }); // Scroll down
						}
					}
				}
			});
		};

		let ticking = false;
		const onScroll = () => {
			if (!ticking) {
				window.requestAnimationFrame(() => {
					updateActiveTOC();
					ticking = false;
				});
				ticking = true;
			}
		};

		window.addEventListener('scroll', onScroll, { passive: true });
		updateActiveTOC(); // initial execution

		return () => {
			window.removeEventListener('scroll', onScroll);
		};
	}

	let cleanup;
	const init = () => {
		if (cleanup) cleanup();
		cleanup = setupScrollSpy();
	};

	// Use astro:page-load for Astro view transitions (if used), or DOMContentLoaded
	document.addEventListener('astro:page-load', init);
	if (document.readyState === 'complete' || document.readyState === 'interactive') {
		init();
	} else {
		document.addEventListener('DOMContentLoaded', init);
	}
</script>

<style>
	.toc {
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 6rem);
		overflow-y: auto;
		padding-left: 1.5rem;
		border-left: 1px solid var(--color-border);
		/* Smooth scrolling behavior for internal scrolling */
		scroll-behavior: smooth;
		/* Hide scrollbar for a cleaner look if desired, but keep functionality */
		scrollbar-width: thin;
		scrollbar-color: var(--color-border) transparent;
	}

	.toc-title {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-ink-faint);
		margin: 0 0 0.75rem 0;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.toc-item {
		margin-bottom: 0.375rem;
	}

	.toc-item--nested {
		padding-left: 1rem;
	}

	.toc-link {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--color-ink-muted);
		text-decoration: none;
		line-height: 1.5;
		transition: color 0.2s ease, font-weight 0.2s ease;
		display: block;
	}

	.toc-link:hover,
	.toc-link.active {
		color: var(--color-accent);
	}

	.toc-link.active {
		font-weight: 600;
	}
</style>

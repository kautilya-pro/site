---
import { SITE_REPO_URL } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] py-8 mt-16">
	<div
		class="mx-auto flex max-w-[var(--width-page)] flex-col items-center gap-4 px-6 sm:flex-row sm:justify-between"
	>
		<p class="font-mono text-xs text-[var(--color-ink-faint)] m-0">
			&copy; {year} Kautilya Bhardwaj
		</p>
		<nav class="flex gap-6">
			<a
				href="/"
				class="font-mono text-xs text-[var(--color-ink-faint)] no-underline transition-colors hover:text-[var(--color-ink-muted)]"
			>
				home
			</a>
			<a
				href={SITE_REPO_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="font-mono text-xs text-[var(--color-ink-faint)] no-underline transition-colors hover:text-[var(--color-ink-muted)]"
			>
				source code
			</a>
		</nav>
	</div>
</footer>

---
interface Props {
	date: Date;
}

const { date } = Astro.props;

const formatted = date.toLocaleDateString('en-CA', {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
}).replace(/-/g, '.');
---

<time
	datetime={date.toISOString()}
	class="font-mono text-sm text-[var(--color-ink-muted)]"
>
	{formatted}
</time>

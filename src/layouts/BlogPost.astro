---
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import {
	PUBLIC_GISCUS_REPO,
	PUBLIC_GISCUS_REPO_ID,
	PUBLIC_GISCUS_CATEGORY,
	PUBLIC_GISCUS_CATEGORY_ID,
} from 'astro:env/client';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	title: string;
	description: string;
	date: Date;
	updatedDate?: Date;
	series: string;
	permalinkSlug: string;
	headings: Heading[];
}

const { title, description, date, updatedDate, series, permalinkSlug, headings } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
	<head>
		<BaseHead title={title} description={description} ogType="article" />
		<SEO
			title={title}
			description={description}
			date={date}
			updatedDate={updatedDate}
			series={series}
			permalinkSlug={permalinkSlug}
			type="article"
		/>
	</head>
	<body>
		<Header />
		<div class="article-grid">
			<article class="article-content">
				<!-- Article Header -->
				<header class="article-header">
					<nav aria-label="Breadcrumb" class="mb-8">
						<ol class="flex items-center space-x-2 text-[0.85rem] font-mono text-[var(--color-ink-muted)]">
							<li>
								<a href="/" class="hover:text-[var(--color-accent)] transition-colors">home</a>
							</li>
							<li>
								<span class="text-[var(--color-ink-faint)] opacity-60">/</span>
							</li>
							<li>
								<a href={`/${series}/`} class="hover:text-[var(--color-accent)] transition-colors">{series}</a>
							</li>
							<li>
								<span class="text-[var(--color-ink-faint)] opacity-60">/</span>
							</li>
						</ol>
					</nav>

					<h1 class="article-title">{title}</h1>
					<p class="article-description">{description}</p>
					
					<div class="article-meta mt-6 !mb-0 text-[var(--color-ink-faint)] font-mono text-sm">
						<span class="mr-2">Published:</span>
						<FormattedDate date={date} />
						{
							updatedDate && (
								<>
									<span class="meta-separator mx-2">·</span>
									<span class="updated-label">
										Updated <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</div>
				</header>

				<hr class="article-divider" />

				<!-- Article Body -->
				<div class="prose">
					<slot />
				</div>

				<hr class="article-divider" />

				<!-- Giscus Comments Placeholder -->
				<section id="giscus-comments" class="comments-section">
					<h2 class="comments-title">Comments</h2>
					<script is:inline src="https://giscus.app/client.js"
						data-repo={PUBLIC_GISCUS_REPO}
						data-repo-id={PUBLIC_GISCUS_REPO_ID}
						data-category={PUBLIC_GISCUS_CATEGORY}
						data-category-id={PUBLIC_GISCUS_CATEGORY_ID}
						data-mapping="pathname"
						data-strict="0"
						data-reactions-enabled="1"
						data-emit-metadata="0"
						data-input-position="bottom"
						data-theme="transparent_dark"
						data-lang="en"
						data-loading="lazy"
						crossorigin="anonymous"
						async>
					</script>
				</section>
			</article>

			<!-- Table of Contents Sidebar -->
			<aside class="article-sidebar">
				<TableOfContents headings={headings} />
			</aside>
		</div>
		<Footer />
	</body>
</html>

<style>
	.article-grid {
		display: grid;
		grid-template-columns: 1fr 250px;
		gap: 3rem;
		max-width: var(--width-page);
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	.article-content {
		min-width: 0;
		max-width: 100%;
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}


	.meta-separator {
		color: var(--color-ink-faint);
	}

	.updated-label {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-ink-muted);
		font-style: italic;
	}

	.article-title {
		font-size: 2.5rem;
		line-height: 1.15;
		margin-bottom: 0.75rem;
		letter-spacing: -0.025em;
	}

	.article-description {
		font-family: var(--font-serif);
		font-size: 1.125rem;
		color: var(--color-ink-muted);
		line-height: 1.6;
		margin: 0;
	}

	.article-divider {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 2.5rem 0;
	}

	.article-sidebar {
		display: block;
	}

	/* Comments */
	.comments-section {
		margin-top: 1rem;
	}

	.comments-title {
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.comments-placeholder {
		border: 1px dashed var(--color-border-subtle);
		border-radius: 8px;
		padding: 1.5rem;
		text-align: center;
	}

	.comments-placeholder p {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--color-ink-muted);
		margin: 0.25rem 0;
	}

	.comments-hint {
		color: var(--color-ink-faint) !important;
		font-size: 0.75rem !important;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.article-grid {
			grid-template-columns: 1fr;
			padding: 2rem 1rem;
		}

		.article-sidebar {
			display: none;
		}

		.article-title {
			font-size: 2rem;
		}
	}
</style>

PUBLIC_GA_TRACKING_ID="G-XXXXXXXXXX"

# Giscus Comments
PUBLIC_GISCUS_REPO="username/repo"
PUBLIC_GISCUS_REPO_ID="R_XXXXXXXXXX"
PUBLIC_GISCUS_CATEGORY="Announcements"
PUBLIC_GISCUS_CATEGORY_ID="DIC_XXXXXXXXXX"

# Cloudflare Turnstile (Newsletter Spam Protection)
# Use official dummy keys for local development (they always pass)
# Site Key: 1x00000000000000000000AA
# Secret Key: 1x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
